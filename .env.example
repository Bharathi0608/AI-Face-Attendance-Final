# ─── FaceAttend Environment Configuration ───────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Flask secret key (change this to a random string in production)
SECRET_KEY=change_this_to_a_random_secret_key_xyz_2024

# Firebase project details (get from Firebase Console → Project Settings → General)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Admin credentials (hardcoded defaults shown below)
# These match what's set in app.py — change both if you update them
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Admin@1234

# Face recognition settings
FACE_TOLERANCE=0.50
DEFAULT_SCAN_SECONDS=30

# Server settings
FLASK_PORT=5000
FLASK_DEBUG=true
